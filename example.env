#'LOCAL' | 'STAGING' | 'PRODUCTION' ЗДЕСЬ МОГУТ БЫТЬ ТОЛЬКО ЭТИ ЗНАЧЕНИЯ
ENVIRONMENT=LOCAL
DB_HOST=string
DB_PORT=number
DB_USER=string
DB_PASSWORD=string
DB_NAME=string
#DATABASE_URL переименовывать нельзя иначе prisma прочитать не сможет
DATABASE_URL=postgres://YourUserName:YourPassword@YourHostname:5432/YourDatabaseName

FIRST_APP_PORT=number
SECOND_APP_PORT=number

EMAIL_USER=string
EMAIL_PASS=string

ACCESS_TOKEN_SECRET=string
REFRESH_TOKEN_SECRET=string

GOOGLE_CLIENT_ID=string
GOOGLE_CLIENT_SECRET=string

GITHUB_CLIENT_ID=string
GITHUB_CLIENT_SECRET=string

RECAPTCHA_SECRET_KEY=string

FRONTEND_URL=string

YANDEX_ENDPOINT=https://storage.yandexcloud.net
YANDEX_REGION=us-east-1
YANDEX_ACCESS_KEY_ID=string
YANDEX_SECRET_ACCESS_KEY=string
YANDEX_S3_BUCKET=inctagram-bucket

RABBITMQ_URL=amqp://localhost
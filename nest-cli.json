{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "apps/first-app/src",
  "compilerOptions": {
    "deleteOutDir": true,
    "webpack": true,
    "tsConfigPath": "apps/first-app/tsconfig.app.json"
  },
  "monorepo": true,
  "root": "apps/first-app",
  "projects": {
    "first-app": {
      "type": "application",
      "root": "apps/first-app",
      "entryFile": "main",
      "sourceRoot": "apps/first-app/src",
      "compilerOptions": {
        "tsConfigPath": "apps/first-app/tsconfig.app.json"
      }
    },
    "second-app": {
      "type": "application",
      "root": "apps/second-app",
      "entryFile": "main",
      "sourceRoot": "apps/second-app/src",
      "compilerOptions": {
        "tsConfigPath": "apps/second-app/tsconfig.app.json"
      }
    },
    "config": {
      "type": "library",
      "root": "libs/config",
      "entryFile": "index",
      "sourceRoot": "libs/config/src",
      "compilerOptions": {
        "tsConfigPath": "libs/config/tsconfig.lib.json"
      }
    },
    "common-decorators": {
      "type": "library",
      "root": "libs/common-decorators",
      "entryFile": "index",
      "sourceRoot": "libs/common-decorators/src",
      "compilerOptions": {
        "tsConfigPath": "libs/common-decorators/tsconfig.lib.json"
      }
    },
    "jwt-token": {
      "type": "library",
      "root": "libs/jwt-token",
      "entryFile": "index",
      "sourceRoot": "libs/jwt-token/src",
      "compilerOptions": {
        "tsConfigPath": "libs/jwt-token/tsconfig.lib.json"
      }
    },
    "common-guards": {
      "type": "library",
      "root": "libs/common-guards",
      "entryFile": "index",
      "sourceRoot": "libs/common-guards/src",
      "compilerOptions": {
        "tsConfigPath": "libs/common-guards/tsconfig.lib.json"
      }
    },
    "repositories": {
      "type": "library",
      "root": "libs/repositories",
      "entryFile": "index",
      "sourceRoot": "libs/repositories/src",
      "compilerOptions": {
        "tsConfigPath": "libs/repositories/tsconfig.lib.json"
      }
    }
  }
}